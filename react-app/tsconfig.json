{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es5",
    "jsx": "react",

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strictNullChecks": false,

    "lib": ["dom", "es2015"],

    "baseUrl": "./src",
    "sourceMap": true,
    "outDir": "./dist/ts"
  },
  "exclude": [
    "node_modules", "dist"
  ]
}
